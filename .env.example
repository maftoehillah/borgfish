# Borgfish environment example (production-safe)
# Copy this file to `.env` and fill values locally or via your secret manager.
# This file is safe to publish — it contains NO secrets.
#
# Important:
# - Never commit your `.env` file to source control.
# - Use CI/CD protected secrets or a secrets manager for production values.
# - After copying to `.env`, run: `php artisan key:generate` to set `APP_KEY`.

APP_NAME=Borgfish
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance settings
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP CLI settings (uncomment for long-running CLI workers)
# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database (default: sqlite for local development)
DB_CONNECTION=sqlite
# For MySQL, uncomment and set the values in your local `.env` (DO NOT commit secrets):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# Broadcast / Filesystem / Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
FILESYSTEM_PUBLIC_URL=/storage
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (default: log for local/dev)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth (Socialite) - set values per environment
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Admin whitelist (comma-separated). Keep empty here for safety.
ADMIN_GOOGLE_WHITELIST=

# Payment gateway (TriPay) — DO NOT commit API keys into source control
PAYMENT_GATEWAY=tripay
TRIPAY_ENVIRONMENT=sandbox
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_SANDBOX_API_KEY=
TRIPAY_SANDBOX_PRIVATE_KEY=
TRIPAY_SANDBOX_MERCHANT_CODE=
TRIPAY_PRODUCTION_API_KEY=
TRIPAY_PRODUCTION_PRIVATE_KEY=
TRIPAY_PRODUCTION_MERCHANT_CODE=
TRIPAY_SANDBOX_BASE_URL=https://tripay.co.id/api-sandbox
TRIPAY_LIVE_BASE_URL=https://tripay.co.id/api
TRIPAY_CALLBACK_URL="${APP_URL}/api/tripay/callback"
TRIPAY_RETURN_URL="${APP_URL}"
TRIPAY_DEFAULT_METHOD=QRIS
TRIPAY_SYNC_METHODS=true
TRIPAY_METHOD_CACHE_MINUTES=30
TRIPAY_RECONCILE_PENDING_AFTER_SECONDS=90

# WhatsApp / notification drivers — keep tokens empty in repo
WHATSAPP_DRIVER=fonnte
WHATSAPP_SHOW_DEV_OTP=false
WHATSAPP_SENDER_NAME=Borgfish
WHATSAPP_FAIL_SILENTLY=false
FONNTE_ENDPOINT=https://api.fonnte.com/send
FONNTE_TOKEN=
WABLAS_ENDPOINT=https://wablas.com/api/send-message
WABLAS_TOKEN=
WABLAS_SECRET_KEY=
WHATSAPP_ENDPOINT=
WHATSAPP_TOKEN=
WHATSAPP_SECRET=
WHATSAPP_AUTH_HEADER=Authorization
WHATSAPP_AUTH_SCHEME=Bearer
WHATSAPP_RECIPIENT_KEY=to
WHATSAPP_MESSAGE_KEY=message

# OTP / rate limiting defaults
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESEND=3
OTP_RATE_LIMIT_PER_HOUR=6
OTP_RATE_LIMIT_PER_NUMBER_PER_HOUR=6
OTP_RESEND_COOLDOWN_SECONDS=60

# Dev/testing flags — do NOT enable in production
BYPASS_ONBOARDING=false
MAINTENANCE_MODE=false
MAINTENANCE_HTML_PATH=
MAINTENANCE_STATUS=503
MAINTENANCE_EXCEPT=up,api/tripay/callback

# Auction defaults
AUCTION_PAYMENT_DEADLINE_MINUTES=30
PAYMENT_DEADLINE_REMINDER_MINUTES=10
BID_SPAM_COOLDOWN_SECONDS=2

# AWS S3 (for filesystem) — keep empty here; configure in production via secrets
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Notes and safe defaults:
# - Use a secrets manager (AWS/GCP/Azure/GitHub Actions secrets) for production values.
# - If any secret was committed, rotate it immediately and purge git history.
# - For production: set APP_ENV=production, APP_DEBUG=false, set APP_KEY, enable secure cookies and HTTPS.
# Quick local setup:
#   cp .env.example .env
#   php artisan key:generate
#   php artisan migrate --seed
